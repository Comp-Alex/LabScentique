# LabScentique Environment Configuration
# Copy this file to .env and update values for your environment

# Database Configuration
# Choose: sqlite or postgres
DB_TYPE=sqlite

# For SQLite (local development):
# Note: SQLite is NOT recommended for Vercel (no persistent filesystem)
DB_PATH=./labscentique.db

# For PostgreSQL (recommended for Vercel):
# Format: postgresql://user:password@host:port/database
# Example: postgresql://user:pass@db.example.com:5432/labscentique
DATABASE_URL=

# Application Settings
APP_ENV=production
APP_DEBUG=false

# Vercel-specific
# These are automatically set by Vercel for serverless functions
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app

# Session Configuration
SESSION_TIMEOUT=3600
SESSION_SECURE=true

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30
