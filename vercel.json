{
  "version": 2,
  "framework": "php",
  "regions": ["iad1"],
  "buildCommand": "npm install",
  "devCommand": "php -S localhost:3000",
  "public": "public",
  "env": {
    "DB_TYPE": {
      "description": "Database type: sqlite or postgres",
      "default": "sqlite"
    },
    "DB_PATH": {
      "description": "For SQLite: path to database file",
      "default": "./tmp/labscentique.db"
    },
    "DATABASE_URL": {
      "description": "For PostgreSQL: Full database connection string"
    }
  },
  "functions": {
    "api/**/*.php": {
      "runtime": "php-8.5"
    },
    "public/**/*.php": {
      "runtime": "php-8.5"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
