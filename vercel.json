{
  "version": 2,
  "framework": "php",
  "public": true,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "functions": {
    "api/**/*.php": {
      "runtime": "php-8.5"
    },
    "public/**/*.php": {
      "runtime": "php-8.5"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/index.php",
      "dest": "/public/index.php"
    },
    {
      "src": "/dashboard.php",
      "dest": "/public/dashboard.php"
    },
    {
      "src": "/profile.php",
      "dest": "/public/profile.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
